{
  "version": 2,
  "name": "ael-store",
  "alias": ["ael-store.vercel.app"],
  "buildCommand": null,
  "outputDirectory": ".",
  "overwrite": true,
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
